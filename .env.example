# ── Servidor ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://tsm.triarcsolutions.com.br

# ── Banco de dados (Supabase PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://postgres:senha@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=triarc-social

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=seu-segredo-jwt-aqui
CRON_SECRET=seu-segredo-cron-aqui

# Primeiro admin (criado automaticamente na primeira execução)
ADMIN_EMAIL=admin@triarcsolutions.com.br
ADMIN_PASSWORD=sua-senha-segura-aqui

# ── LLM — DeepSeek (principal) ────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Fallback: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# ── Geração de imagens — Google Gemini ────────────────────────────
GEMINI_API_KEY=AIza...

# ── News API (pesquisa diária) ────────────────────────────────────
NEWS_API_KEY=...

# ── Instagram Graph API ───────────────────────────────────────────
IG_USER_ID=17841477720751822
IG_USERNAME=triarcsolutions
# Token de longa duração (Page Access Token com permissões instagram_*)
# Alternativa: conectar via OAuth em Contas → Instagram → Conectar
IG_ACCESS_TOKEN=

# ── Facebook ──────────────────────────────────────────────────────
FACEBOOK_APP_ID=839325212106503
FACEBOOK_APP_SECRET=...
PAGE_ID=955553160977534

# ── LinkedIn ──────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=77286ej73x2xu3
LINKEDIN_CLIENT_SECRET=...

# ── AWS S3 (opcional, para storage próprio) ───────────────────────
# S3_BUCKET=meu-bucket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

