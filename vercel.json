{
  "version": 2,
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/index" },
    { "source": "/api/:path*",      "destination": "/api/index" },
    { "source": "/(.*)",             "destination": "/api/index" }
  ]
}
